# Required for build and runtime — add these in Vercel → Project → Settings → Environment Variables
# (Production, Preview, and Development as needed)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=

# Optional — used when NEXT_PUBLIC_API_URL is set in src/types/constants.ts
NEXT_PUBLIC_API_URL=
